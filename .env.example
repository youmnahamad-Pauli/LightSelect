# Root-level example — copy relevant sections to apps/api/.env and apps/web/.env

# Supabase session pooler connection string (port 5432, ?sslmode=require required)
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-generate-a-strong-random-secret

FRONTEND_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
