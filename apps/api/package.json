{
  "name": "@lightselect/api",
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "tsx src/db/migrate.ts && tsx src/db/seed.ts",
    "db:bootstrap": "tsx src/db/bootstrap.ts",
    "db:seed:v3": "tsx src/db/seed-v3-categories.ts",
    "db:seed:v3-signoff": "tsx src/db/seed-v3-signoff.ts",
    "registry:backfill": "tsx src/db/registry-backfill.ts",
    "catalogue:ingest": "tsx src/db/catalogue-ingest.ts",
    "matching:seed": "tsx src/db/matching-seed.ts",
    "export:compliance": "tsx src/db/export-compliance.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.32.0",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/pdfkit": "^0.13.4",
    "drizzle-kit": "^0.23.0",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
