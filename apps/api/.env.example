PORT=3001
DATABASE_URL=postgres://user:password@localhost:5432/lightselect
JWT_SECRET=change-me-before-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Storage — use 'local' for development, 's3' for production
STORAGE_DRIVER=local
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=50

# S3 (only required when STORAGE_DRIVER=s3)
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=lightselect-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
