PORT=3001

# Supabase session pooler connection string (port 5432, ?sslmode=require required)
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-generate-a-strong-random-secret
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Storage — use 'local' for development, 's3' for production
STORAGE_DRIVER=local
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Bootstrap — used once by: pnpm db:bootstrap
# Creates the first organization, admin user, and org_users link.
# Idempotent: safe to re-run (skips if email already exists).
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me

# PDF attribute extraction engine
# 'stub'   — deterministic mock, no API key needed (default)
# 'claude' — real extraction via Anthropic Messages API; requires ANTHROPIC_API_KEY
EXTRACTION_ENGINE=stub

# Required only when EXTRACTION_ENGINE=claude
ANTHROPIC_API_KEY=

# Claude model used for extraction (default: claude-sonnet-4-6)
# EXTRACTION_MODEL=claude-sonnet-4-6

# S3 (only required when STORAGE_DRIVER=s3)
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=lightselect-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
